# ──────────────────────────────────────────────────────────
# 발주Up — 로컬 개발 환경변수 예시
#
# 사용법:
#   1) 이 파일을 .env.local 로 복사
#   2) 각 값을 본인 환경에 맞게 채워 넣기
#   3) .env.local 은 .gitignore 에 포함되어 있어 커밋되지 않음
# ──────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────
# https://supabase.com → 프로젝트 생성 후 Settings → API 에서 발급
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # 서버 전용. 절대 클라이언트에 노출 금지.

# ── Anthropic (Claude API) ───────────────────────────────
# https://console.anthropic.com → API Keys 에서 발급
ANTHROPIC_API_KEY=sk-ant-...

# ── 공공데이터포털 ────────────────────────────────────────
# https://www.data.go.kr → 마이페이지 → 인증키 발급
# 활용신청 API:
#   - 공동주택 단지 목록 (AptListService2)
#   - 공동주택 관리정보 (AptMgmtSvc3)        ← 유지관리이력, 충당금
#   - 공동주택 입찰공고 (AptBidInfoService)
DATA_GO_KR_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 토스페이먼츠 (정기 구독 결제) ─────────────────────────
# https://developers.tosspayments.com → 내 개발정보
# 테스트 키로 시작 → 출시 시 라이브 키로 교체
# Client 키는 NEXT_PUBLIC_ 접두사가 있어야 브라우저에서 사용 가능
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_xxxx
TOSS_SECRET_KEY=test_sk_xxxx

# ── 카카오 알림톡 (비즈메시지) ────────────────────────────
# 솔루션사(루나소프트, 알리고, 인포뱅크 등) 가입 후 발급
KAKAO_API_KEY=
KAKAO_SENDER_KEY=

# ── 카카오맵 JavaScript SDK (단지 위성 사진) ──────────────
# https://developers.kakao.com → 내 애플리케이션 → "JavaScript 키"
# 플랫폼 → Web 사이트 도메인 등록 필수:
#   - http://localhost:3000
#   - https://baljuup.vercel.app  (또는 본인 배포 도메인)
# NEXT_PUBLIC_ 접두사가 있어야 브라우저에서 사용 가능.
# 값이 비어 있으면 단지 전경 카드는 placeholder(외부 지도 링크)로 fallback.
NEXT_PUBLIC_KAKAO_MAP_KEY=

# ── 앱 URL ───────────────────────────────────────────────
# 로컬: http://localhost:3000
# Vercel: https://your-domain.vercel.app
NEXT_PUBLIC_URL=http://localhost:3000

# ── 운영 옵션 (선택) ──────────────────────────────────────
# 공공데이터 수집 스크립트 동시 요청 수 (기본 5, 너무 높이면 API 차단 위험)
COLLECT_CONCURRENCY=5
